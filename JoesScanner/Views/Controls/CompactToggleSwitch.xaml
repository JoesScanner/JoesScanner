<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="JoesScanner.Views.Controls.CompactToggleSwitch"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root"
    HeightRequest="20"
    WidthRequest="45">

    <Border
        x:Name="Track"
        WidthRequest="{Binding Source={x:Reference Root}, Path=WidthRequest}"
        HeightRequest="{Binding Source={x:Reference Root}, Path=HeightRequest}"
        StrokeThickness="0"
        Padding="2"
        HorizontalOptions="Fill"
        VerticalOptions="Center">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="10" />
        </Border.StrokeShape>

        <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
            <Border
                x:Name="Thumb"
                HeightRequest="16"
                WidthRequest="16"
                StrokeThickness="0"
                HorizontalOptions="Start"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
            </Border>
        </Grid>
    </Border>

</ContentView>
