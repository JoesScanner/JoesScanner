<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="JoesScanner.Views.Controls.ExpandableCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Border
        Padding="{Binding CardPadding, Source={x:Reference Root}}"
        Stroke="{Binding CardStroke, Source={x:Reference Root}}"
        StrokeThickness="{Binding CardStrokeThickness, Source={x:Reference Root}}"
        BackgroundColor="{Binding CardBackgroundColor, Source={x:Reference Root}}"
        Margin="{Binding CardMargin, Source={x:Reference Root}}">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="{Binding CardCornerRadius, Source={x:Reference Root}}" />
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto,Auto" RowSpacing="10">

            <!-- Header -->
            <Grid
                Grid.Row="0"
                ColumnDefinitions="*,Auto,Auto"
                ColumnSpacing="10">

                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHeaderTapped" />
                </Grid.GestureRecognizers>

                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label
                        Text="{Binding Title, Source={x:Reference Root}}"
                        FontAttributes="Bold"
                        FontSize="16"
                        TextColor="{Binding TitleColor, Source={x:Reference Root}}" />

                    <Label
                        Text="{Binding Subtitle, Source={x:Reference Root}}"
                        IsVisible="{Binding HasSubtitle, Source={x:Reference Root}}"
                        FontSize="12"
                        Opacity="0.85"
                        TextColor="{Binding SubtitleColor, Source={x:Reference Root}}"
                        LineBreakMode="WordWrap"
                        MaxLines="3" />
                </VerticalStackLayout>

                <ContentPresenter
                    Grid.Column="1"
                    Content="{Binding HeaderRightContent, Source={x:Reference Root}}"
                    BindingContext="{Binding BindingContext, Source={x:Reference Root}}" 
                    VerticalOptions="Center"
                    HorizontalOptions="End"
                    IsVisible="{Binding HasHeaderRightContent, Source={x:Reference Root}}" />

                <Label
                    Grid.Column="2"
                    Text="{Binding ChevronText, Source={x:Reference Root}}"
                    FontSize="18"
                    TextColor="{Binding TitleColor, Source={x:Reference Root}}"
                    VerticalOptions="Center"
                    HorizontalOptions="End" />

            </Grid>

            <!-- Body -->
            <ContentPresenter
                Grid.Row="1"
                Content="{Binding CardContent, Source={x:Reference Root}}"
                BindingContext="{Binding BindingContext, Source={x:Reference Root}}" 
                IsVisible="{Binding IsExpanded, Source={x:Reference Root}}" />

        </Grid>
    </Border>
</ContentView>