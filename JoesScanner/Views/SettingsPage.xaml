<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JoesScanner.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:JoesScanner.ViewModels"
    xmlns:models="clr-namespace:JoesScanner.Models"
    xmlns:controls="clr-namespace:JoesScanner.Views.Controls"
    x:Name="SettingsPageRoot"
    x:DataType="vm:SettingsViewModel"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="{StaticResource TabStripNavy}">
    <ContentPage.Resources>
        <Style x:Key="CompactSwitchStyle" TargetType="Switch">
            <Setter Property="Scale">
                <Setter.Value>
                    <OnPlatform x:TypeArguments="x:Double" Default="0.9">
                        <On Platform="WinUI" Value="0.78" />
                    </OnPlatform>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalOptions" Value="End" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="OnColor" Value="{StaticResource Primary}" />
            <Setter Property="ThumbColor" Value="White" />
        </Style>
        <!-- Platform helper resources (avoid WinUI= property assignment which can be trimmed on iOS) -->
        <OnPlatform x:Key="IsWinUIOnly" x:TypeArguments="x:Boolean" Default="False">
            <On Platform="WinUI" Value="True" />
        </OnPlatform>
    </ContentPage.Resources>

<!-- Scroll so content works on phone and desktop -->
    <Grid Padding="5,0,5,5" RowDefinitions="0,*" RowSpacing="0">

        <ScrollView Grid.Row="1">
            <Border
                        Padding="2"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#020617}"
                        StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>

                <!-- Rows:
                             0 = header
                             1 = connection
                             2 = auto connect (Windows)
                             3 = filters
                             4 = bluetooth labels
                             5 = theme -->
                <Grid
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                            ColumnDefinitions="*">

                    <!-- HEADER PANEL -->
                    <Border
                                Grid.Row="0"
                                BackgroundColor="#0D0D28"
                                Padding="2,0"
                                StrokeThickness="0"
                                Margin="0,0,0,10"
                                HorizontalOptions="Fill">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>

                        <Grid Padding="8,6">

                        <VerticalStackLayout
                            Spacing="0"
                            VerticalOptions="Center">

                            <!-- Title and tagline -->
                            <Grid RowDefinitions="Auto,Auto"
                                ColumnDefinitions="*,Auto">

                                <!-- Row 0: Title (left) + Version (right) -->
                                <Label
                                    Grid.Row="0"
                                                                        Text="Adjust connection, call list behavior, filters and theme"
                                    FontSize="12"
                                    LineBreakMode="WordWrap"
                                    TextColor="White" />
                                <Label
                                    x:Name="AppVersionLabel"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Text=""
                                    FontSize="12"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    TextColor="White" />

                            </Grid>

                            <!-- Header status -->
                            <Grid
                                        ColumnDefinitions="*"
                                        HorizontalOptions="Fill"
                                        Padding="0,0,0,0">

                                <VerticalStackLayout
                                            Spacing="0"
                                            HorizontalOptions="FillAndExpand"
                                            VerticalOptions="Center">

                                    <Label
                                                Text="Validating server..."
                                                IsVisible="{Binding ShowServerValidationProgressHeader}"
                                                FontSize="14"
                                                TextColor="#cbd5e1"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                MaxLines="2" />

                                    <Label
                                                Text="{Binding ValidationSuccessHeaderText}"
                                                IsVisible="{Binding ShowServerValidationSuccessHeader}"
                                                FontSize="14"
                                                TextColor="{AppThemeBinding Light=#16a34a, Dark=#22c55e}"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                MaxLines="2" />

                                    <Label
                                                Text="{Binding ServerValidationMessage}"
                                                IsVisible="{Binding ShowServerValidationErrorHeader}"
                                                FontSize="14"
                                                TextColor="{AppThemeBinding Light=#dc2626, Dark=#f87171}"
                                                HorizontalOptions="FillAndExpand"
                                                LineBreakMode="WordWrap"
                                                MaxLines="3" />

                                </VerticalStackLayout>

                            </Grid>

                        </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <!-- CONNECTION CARD -->
                    <Border
    Grid.Row="1"
    Padding="10"
    BackgroundColor="{AppThemeBinding Light=#f9fafb, Dark=#020617}"
    StrokeThickness="1"
    StrokeShape="RoundRectangle 16"
    Margin="0,0,0,12">

                        <Grid
        RowDefinitions="Auto,Auto,Auto"
        ColumnDefinitions="*,Auto"
        RowSpacing="6"
        ColumnSpacing="12">

                            <!-- Row 0: Title left -->
                            <Label
            Grid.Row="0"
                        Text="Connection"
            FontAttributes="Bold"
            FontSize="16"
            HorizontalOptions="Start"
            TextColor="{AppThemeBinding Light=#111827, Dark=White}" />

                            <!-- Row 0: Subscription right -->
                            <Label
            Grid.Row="0"
            Grid.Column="1"
            Text="{Binding SubscriptionSummary}"
            IsVisible="{Binding ShowSubscriptionSummary}"
            FontSize="10"
            TextColor="{AppThemeBinding Light=#16a34a, Dark=#22c55e}"
            HorizontalTextAlignment="End"
            VerticalOptions="Center"
            LineBreakMode="WordWrap"
            MaxLines="2" />

                            <!-- Row 1: Description spans both columns -->
                            <Label
            Grid.Row="1"
                        Grid.ColumnSpan="2"
            Margin="0,0,0,4"
            Text="Choose which server the app connects to. Not all servers require user/pass."
            FontSize="12"
            TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
            LineBreakMode="WordWrap"
            MaxLines="3" />

                            <!-- Row 2: Fields -->
                            <Grid
            Grid.Row="2"
                        Grid.ColumnSpan="2"
            RowDefinitions="Auto,Auto,Auto"
            ColumnDefinitions="*"
            RowSpacing="8">

                                <!-- Server row -->
                                <Grid
                Grid.Row="0"
                ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8"
                VerticalOptions="Center">

                                    <Label
                                        Text="Server"
                    FontSize="12"
                    VerticalOptions="Center" />

                                    <Entry
                    Grid.Column="1"
                    Text="{Binding ServerUrl}"
                    Placeholder="https://app.joesscanner.com"
                    FontSize="12"
                    VerticalOptions="Center" />

                                    <HorizontalStackLayout
                    Grid.Column="2"
                    Spacing="6"
                    VerticalOptions="Center">

                                        <Button
                        Text="Joe's server"
                        Command="{Binding ResetServerCommand}"
                        Style="{StaticResource SecondaryPillButtonStyle}" />

                                        <Button
                        Text="Validate"
                        Command="{Binding ValidateServerCommand}"
                        Style="{StaticResource PillButtonStyle}">
                                            <Button.Triggers>
                                                <DataTrigger
                                TargetType="Button"
                                Binding="{Binding ConnectionNeedsValidation}"
                                Value="True">
                                                    <Setter Property="BackgroundColor" Value="Red" />
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>

                                    </HorizontalStackLayout>
                                </Grid>

                                <!-- Username and password row -->
                                <Grid
                Grid.Row="1"
                ColumnDefinitions="Auto,*,Auto,*,Auto"
                ColumnSpacing="6">

                                    <Label
                                        Text="User"
                    FontSize="12"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

                                    <Entry
                    Grid.Column="1"
                    Text="{Binding BasicAuthUsername}"
                    Placeholder="username for restricted servers"
                    FontSize="12"
                    HeightRequest="30" />

                                    <Label
                    Grid.Column="2"
                    Text="Pass"
                    FontSize="12"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

                                    <Entry
                    Grid.Column="3"
                    Text="{Binding BasicAuthPassword}"
                    Placeholder="password for restricted servers"
                    IsPassword="{Binding IsBasicAuthPasswordHidden}"
                    FontSize="12"
                    HeightRequest="30"
                    Margin="0,0,4,0" />

                                    <Button
                    Grid.Column="4"
                    Text="{Binding BasicAuthPasswordToggleText}"
                    Command="{Binding ToggleBasicAuthPasswordVisibilityCommand}"
                    Style="{StaticResource SecondaryPillButtonStyle}"
                    VerticalOptions="Center" />
                                </Grid>

                            </Grid>

                        </Grid>
                    </Border>


                    <!-- AUTO CONNECT OPTIONS (WINDOWS ONLY) -->
                    <Border
                                    Grid.Row="2"
                                    Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#374151}"
                                    StrokeThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,12"
                                    BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#111827}"
                                    StrokeShape="RoundRectangle 8">

                                    <Grid
                                        RowDefinitions="Auto,Auto,Auto"
                                        ColumnDefinitions="*,Auto"
                                        RowSpacing="8"
                                        ColumnSpacing="12"
                                        HorizontalOptions="FillAndExpand">

                                        <Label
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Text="Autoplay options"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#111827, Dark=#f9fafb}"
                                            Margin="0,0,0,6" />

                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Text="Autoplay (start playing calls when app opens)"
                                            FontSize="12"
                                            LineBreakMode="WordWrap"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Fill" />

                                        <Switch
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            IsToggled="{Binding AutoPlay}"
                                            Style="{StaticResource CompactSwitchStyle}" />


                                        <Label
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Text="Automatically start when Windows loads"
                                            IsVisible="{StaticResource IsWinUIOnly}"
                                            FontSize="12"
                                            LineBreakMode="WordWrap"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Fill"
                                             />

                                        <Switch
                                            Grid.Row="2"
                                            Grid.Column="1"
                                            IsToggled="{Binding WindowsStartWithWindows}"
                                            IsVisible="{StaticResource IsWinUIOnly}"
                                            Style="{StaticResource CompactSwitchStyle}" />
                                    </Grid>

                    </Border>

                    <!-- FILTERS CARD -->
                    <Border
                                    Grid.Row="3"
                                    Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#374151}"
                                    StrokeThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,12"
                                    BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#111827}"
                                    StrokeShape="RoundRectangle 8">

                        <VerticalStackLayout Spacing="8">

                            <!-- Header -->
                            <Label
                                            Text="Filters"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

                            <Label
                                            Text="Mute or hide traffic by Receiver, Site, or Talkgroup."
                                            FontSize="12"
                                            Opacity="0.8"
                                            TextColor="{AppThemeBinding Light=#4b5563, Dark=#d1d5db}" />





<!-- Table header row -->
                            <Grid
                                            ColumnDefinitions="*,50,50,60"
                                            RowDefinitions="Auto"
                                            Padding="5,4,5,2">

                                <Label
                                                                                                Text="Receiver > Site > Talkgroup"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center" />

                                <Label
                                                Grid.Column="1"
                                                Text="Mute"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                VerticalOptions="Center" />

                                <Label
                                                Grid.Column="2"
                                                Text="Disable"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                VerticalOptions="Center" />

                                <Label
                                                Grid.Column="3"
                                                Text="Clear"
                                                FontSize="11"
                                                FontAttributes="Bold"
                                                HorizontalOptions="Center"
                                                HorizontalTextAlignment="Center"
                                                VerticalOptions="Center" />
                            </Grid>

                            <!-- Filters table -->
                            <CollectionView
                                            x:Name="FiltersList"
                                            ItemsSource="{Binding FilterRules}"
                                            VerticalOptions="Fill"
                                            SelectionMode="None">

                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout
                                                    Orientation="Vertical"
                                                    ItemSpacing="2" />
                                </CollectionView.ItemsLayout>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FilterRule">
                                        <Grid
                                                        ColumnDefinitions="*,50,50,60"
                                                        Padding="0,2">

                                            <!-- Display key -->
                                            <Label
                                                                                                                        Text="{Binding DisplayKey}"
                                                            FontSize="11"
                                                            LineBreakMode="TailTruncation"
                                                            MaxLines="1"
                                                            VerticalOptions="Center" />

                                            <!-- Mute "button" -->
                                            <Border
                                                            Grid.Column="1"
                                                            Stroke="{AppThemeBinding Light=#d1d5db, Dark=#4b5563}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 4"
                                                            Padding="5,4,5,2"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center"
                                                            BackgroundColor="Transparent">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                                    Tapped="OnMuteFilterTapped"
                                                                    CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>

                                                <Label
                                                                FontSize="10"
                                                                HorizontalOptions="Center"
                                                                VerticalOptions="Center">
                                                    <Label.Triggers>
                                                        <!-- When muted, show Unmute -->
                                                        <DataTrigger
                                                                        TargetType="Label"
                                                                        Binding="{Binding IsMuted}"
                                                                        Value="True">
                                                            <Setter Property="Text" Value="Unmute" />
                                                        </DataTrigger>
                                                        <!-- When not muted, show Mute -->
                                                        <DataTrigger
                                                                        TargetType="Label"
                                                                        Binding="{Binding IsMuted}"
                                                                        Value="False">
                                                            <Setter Property="Text" Value="Mute" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Border.Triggers>
                                                    <!-- Muted = yellow -->
                                                    <DataTrigger
                                                                    TargetType="Border"
                                                                    Binding="{Binding IsMuted}"
                                                                    Value="True">
                                                        <Setter Property="BackgroundColor" Value="#f59e0b" />
                                                    </DataTrigger>

                                                    <!-- Not muted = clear -->
                                                    <DataTrigger
                                                                    TargetType="Border"
                                                                    Binding="{Binding IsMuted}"
                                                                    Value="False">
                                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <!-- Disable "button" -->
                                            <Border
                                                            Grid.Column="2"
                                                            Stroke="{AppThemeBinding Light=#d1d5db, Dark=#4b5563}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 4"
                                                            Padding="5,4,5,2"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center"
                                                            BackgroundColor="Transparent">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                                    Tapped="OnDisableFilterTapped"
                                                                    CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>

                                                <Label
                                                                FontSize="10"
                                                                HorizontalOptions="Center"
                                                                VerticalOptions="Center">
                                                    <Label.Triggers>
                                                        <!-- When disabled, show Enable -->
                                                        <DataTrigger
                                                                        TargetType="Label"
                                                                        Binding="{Binding IsDisabled}"
                                                                        Value="True">
                                                            <Setter Property="Text" Value="Enable" />
                                                        </DataTrigger>
                                                        <!-- When not disabled, show Disable -->
                                                        <DataTrigger
                                                                        TargetType="Label"
                                                                        Binding="{Binding IsDisabled}"
                                                                        Value="False">
                                                            <Setter Property="Text" Value="Disable" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>

                                                <Border.Triggers>
                                                    <!-- Disabled = red -->
                                                    <DataTrigger
                                                                    TargetType="Border"
                                                                    Binding="{Binding IsDisabled}"
                                                                    Value="True">
                                                        <Setter Property="BackgroundColor" Value="#ef4444" />
                                                    </DataTrigger>

                                                    <!-- Not disabled = clear -->
                                                    <DataTrigger
                                                                    TargetType="Border"
                                                                    Binding="{Binding IsDisabled}"
                                                                    Value="False">
                                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                            </Border>

                                            <!-- Clear "button" -->
                                            <Border
                                                            Grid.Column="3"
                                                            Stroke="{AppThemeBinding Light=#d1d5db, Dark=#4b5563}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 4"
                                                            Padding="5,4,5,2"
                                                            HorizontalOptions="Center"
                                                            VerticalOptions="Center"
                                                            BackgroundColor="Transparent">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                                    Tapped="OnClearFilterTapped"
                                                                    CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>

                                                <Label
                                                                FontSize="10"
                                                                Text="Clear"
                                                                HorizontalOptions="Center"
                                                                VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- BLUETOOTH LABELS CARD -->
                    <Border
                                    Grid.Row="4"
                                    Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#374151}"
                                    StrokeThickness="1"
                                    Padding="10"
                                    BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#111827}"
                                    StrokeShape="RoundRectangle 8"
                                    Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="6">
                            <Label
                                            Text="Bluetooth labels"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

                            <Label
                                            Text="Choose which call fields show up on your Bluetooth device. Not all devices display all fields."
                                            FontSize="12"
                                            Margin="0,0,0,2"
                                            Opacity="0.8"
                                            TextColor="{AppThemeBinding Light=#4b5563, Dark=#d1d5db}" />

                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="Auto,*"
                                  RowSpacing="4"
                                  ColumnSpacing="10">

                                <Label Grid.Row="0" Text="Artist" FontSize="12" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />
                                <Picker Grid.Row="0" Grid.Column="1"
                                        ItemsSource="{Binding BluetoothLabelOptions}"
                                        SelectedItem="{Binding BluetoothLabelArtistOption}"
                                        ItemDisplayBinding="{Binding Label}"
                                        FontSize="13"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center" />

                                <Label Grid.Row="1" Text="Title" FontSize="12" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />
                                <Picker Grid.Row="1" Grid.Column="1"
                                        ItemsSource="{Binding BluetoothLabelOptions}"
                                        SelectedItem="{Binding BluetoothLabelTitleOption}"
                                        ItemDisplayBinding="{Binding Label}"
                                        FontSize="13"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center" />

                                <Label Grid.Row="2" Text="Album" FontSize="12" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />
                                <Picker Grid.Row="2" Grid.Column="1"
                                        ItemsSource="{Binding BluetoothLabelOptions}"
                                        SelectedItem="{Binding BluetoothLabelAlbumOption}"
                                        ItemDisplayBinding="{Binding Label}"
                                        FontSize="13"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center" />

                                <Label Grid.Row="3" Text="Composer" FontSize="12" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />
                                <Picker Grid.Row="3" Grid.Column="1"
                                        ItemsSource="{Binding BluetoothLabelOptions}"
                                        SelectedItem="{Binding BluetoothLabelComposerOption}"
                                        ItemDisplayBinding="{Binding Label}"
                                        FontSize="13"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center" />

                                <Label Grid.Row="4" Text="Genre" FontSize="12" VerticalOptions="Center" TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />
                                <Picker Grid.Row="4" Grid.Column="1"
                                        ItemsSource="{Binding BluetoothLabelOptions}"
                                        SelectedItem="{Binding BluetoothLabelGenreOption}"
                                        ItemDisplayBinding="{Binding Label}"
                                        FontSize="13"
                                        HorizontalOptions="FillAndExpand"
                                        VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- THEME CARD -->
                    <Border
                                    Grid.Row="5"
                                    Stroke="{AppThemeBinding Light=#e5e7eb, Dark=#374151}"
                                    StrokeThickness="1"
                                    Padding="12"
                                    BackgroundColor="{AppThemeBinding Light=#ffffff, Dark=#111827}"
                                    StrokeShape="RoundRectangle 8">

                        <VerticalStackLayout Spacing="10">
                            <Label
                                            Text="Theme"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

                            <Label
                                            Text="Choose System, Light, or Dark."
                                            FontSize="12"
                                            Opacity="0.8"
                                            TextColor="{AppThemeBinding Light=#4b5563, Dark=#d1d5db}" />

                            <VerticalStackLayout Spacing="6">
                                <HorizontalStackLayout Spacing="10">
                                    <RadioButton
                                                    Content="System"
                                                    IsChecked="{Binding IsThemeSystem}" />
                                    <RadioButton
                                                    Content="Light"
                                                    IsChecked="{Binding IsThemeLight}" />
                                    <RadioButton
                                                    Content="Dark"
                                                    IsChecked="{Binding IsThemeDark}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </Border>
        </ScrollView>

    </Grid>
</ContentPage>
