                                    StrokeShape="RoundRectangle 8">

    <VerticalStackLayout Spacing="10">

        <!-- Header -->
        <Grid x:Name="LogHeaderGrid" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLogHeaderTapped" />
            </Grid.GestureRecognizers>

            <Label
                Grid.Column="0"
                Text="Log"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light=#111827, Dark=#e5e7eb}" />

            <Label
                x:Name="LogChevronLabel"
                Grid.Column="1"
                Text="▶"
