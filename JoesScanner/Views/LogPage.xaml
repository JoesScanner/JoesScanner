<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JoesScanner.Views.LogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:JoesScanner.Views.Controls"
    xmlns:models="clr-namespace:JoesScanner.Models"
    xmlns:corecontrols="clr-namespace:JoesScanner.Controls"
    Title="Log"
    BackgroundColor="{StaticResource TabStripNavy}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">


	<Grid Padding="5,0,5,5" RowDefinitions="0,*" RowSpacing="0">

		<Border
            Grid.Row="1"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#020617}"
			VerticalOptions="FillAndExpand"
			HorizontalOptions="FillAndExpand">

			<Border.StrokeShape>
				<RoundRectangle CornerRadius="10" />
			</Border.StrokeShape>

			<Grid Padding="2" RowDefinitions="Auto,*" ColumnDefinitions="*" RowSpacing="8">

				<Border
					Grid.Row="0"
					BackgroundColor="#0D0D28"
					Padding="2,0"
					VerticalOptions="Center"
					HorizontalOptions="Fill">

                    <Border.StrokeShape>
						<RoundRectangle CornerRadius="10" />
					</Border.StrokeShape>

					<Grid Padding="8,6" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
						<HorizontalStackLayout
							Grid.Row="0"
                            Grid.Column="0"
                            Grid.ColumnSpan="{OnIdiom Phone=2, Default=1}"
							Spacing="8"
							HorizontalOptions="Start">
<Button
								Text="Load"
								Style="{StaticResource SecondaryPillButtonStyle}"
							Clicked="OnLoadClicked" />
                            
                            <Button
								Text="Export"
								Style="{StaticResource SecondaryPillButtonStyle}"
								Clicked="OnExportClicked" />
                            <Button
								x:Name="AutoRefreshButton"
								Text="Auto-refresh"
								Style="{StaticResource SecondaryPillButtonStyle}"
								Clicked="OnAutoRefreshClicked" />

                            <Border
								Stroke="#334155"
								StrokeThickness="1"
								BackgroundColor="White"
								Padding="0"
								Margin="0"
								VerticalOptions="Center"
								HeightRequest="22"
								WidthRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAutoRefreshIntervalTapped" />
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Label
										x:Name="AutoRefreshIntervalLabel"
										InputTransparent="True"
										FontSize="13"

										TextColor="Black"
										VerticalOptions="Center"
										HorizontalOptions="Center" />
					</Grid>
                            </Border>

                            <Button
								Text="Copy"
								Style="{StaticResource SecondaryPillButtonStyle}"
								Clicked="OnCopyClicked" />
						</HorizontalStackLayout>

                            <HorizontalStackLayout
                                Grid.Row="0"
                                Grid.Column="1"
                                Spacing="6"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label
                                    x:Name="LoggingStateLabel"
                                    FontSize="13"
                                    TextColor="White"
                                    VerticalOptions="Center" />
                                <controls:CompactToggleSwitch
                                    x:Name="LoggingSwitch"
                                    WidthRequest="56"
                                    HeightRequest="20"
                                    OnColor="#3B82F6"
                                    ThumbColor="White"
                                    Toggled="OnLoggingToggled"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
					</Grid>
				</Border>

			<corecontrols:SelectableEditor
					Grid.Row="1"
					x:Name="LogEditor"
					IsReadOnly="True"
					AutoSize="Disabled"
					FontFamily="Courier New"
					FontSize="12"
					TextColor="{AppThemeBinding Light=#111827, Dark=White}"
					BackgroundColor="Transparent"
					Margin="2"
					VerticalOptions="FillAndExpand"
					HorizontalOptions="FillAndExpand" />

			</Grid>
        </Border>
    </Grid>
</ContentPage>
