<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JoesScanner.Views.LogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:JoesScanner.Views.Controls"
    xmlns:models="clr-namespace:JoesScanner.Models"
    Title="Log"
    BackgroundColor="{StaticResource TabStripNavy}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">


	<Grid Padding="5,0,5,5" RowDefinitions="0,*" RowSpacing="0">

		<Border
            Grid.Row="1"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#020617}"
			VerticalOptions="FillAndExpand"
			HorizontalOptions="FillAndExpand">

			<Border.StrokeShape>
				<RoundRectangle CornerRadius="10" />
			</Border.StrokeShape>

			<Grid Padding="2" RowDefinitions="Auto,*" ColumnDefinitions="*" RowSpacing="8">

				<Border
					Grid.Row="0"
					BackgroundColor="#0D0D28"
					Padding="2,0"
					VerticalOptions="Center"
					HorizontalOptions="Fill">

                    <Border.StrokeShape>
						<RoundRectangle CornerRadius="10" />
					</Border.StrokeShape>

					<Grid 
                        Padding="8,6" 
                        ColumnDefinitions="*" 
                        RowDefinitions="Auto">
						<HorizontalStackLayout
							Grid.Row="0"
							Spacing="8"
							HorizontalOptions="Start">
                            <Label
                                Text="Log"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="White"
                                VerticalOptions="Center" />
                            <Button
								Text="Load"
								Style="{StaticResource SecondaryPillButtonStyle}"
							Clicked="OnLoadClicked" />
                            <Button
								x:Name="AutoRefreshButton"
								Text="Auto-refresh"
								Style="{StaticResource SecondaryPillButtonStyle}"
								Clicked="OnAutoRefreshClicked" />

                            <Border
								Stroke="#334155"
								StrokeThickness="1"
								BackgroundColor="White"
								Padding="0"
								Margin="0"
								VerticalOptions="Center"
								HeightRequest="22"
								WidthRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAutoRefreshIntervalTapped" />
                                </Border.GestureRecognizers>
                                <Grid>
                                    <Label
										x:Name="AutoRefreshIntervalLabel"
										InputTransparent="True"
										FontSize="13"
                                        
										TextColor="Black"
										VerticalOptions="Center"
										HorizontalOptions="Center" />
                                </Grid>
                            </Border>

                            <Button
								Text="Copy"
								Style="{StaticResource SecondaryPillButtonStyle}"
								Clicked="OnCopyClicked" />
						</HorizontalStackLayout>
					</Grid>
				</Border>

				<Editor
					Grid.Row="1"
					x:Name="LogEditor"
					IsReadOnly="True"
					AutoSize="Disabled"
					FontFamily="Courier New"
					FontSize="12"
					TextColor="{AppThemeBinding Light=#111827, Dark=White}"
					BackgroundColor="Transparent"
					Margin="2"
					VerticalOptions="FillAndExpand"
					HorizontalOptions="FillAndExpand" />

			</Grid>
        </Border>
    </Grid>
</ContentPage>
