<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JoesScanner.Views.RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:JoesScanner.Views.Controls"
    BackgroundColor="{StaticResource TabStripNavy}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid
        Padding="5,0,5,5"
        RowDefinitions="Auto,*"
        RowSpacing="0">

        <controls:AppTabStrip
            x:Name="TabStrip"
            Grid.Row="0" />

        <Grid Grid.Row="1">

            <Grid
                x:Name="ContentHost" />

            <!--
                WarmupHost is an invisible, tiny host used to force MAUI to create native handlers and
                run the first layout pass for heavy pages (notably Settings) before the user taps them.
                This removes the "first open" hitch without changing the visible UI.
            -->
            <ContentView
                x:Name="WarmupHost"
                Opacity="0.01"
                InputTransparent="True"
                HeightRequest="1"
                WidthRequest="1"
                HorizontalOptions="Start"
                VerticalOptions="Start" />

            <Grid
                x:Name="NavigationFeedbackOverlay"
                IsVisible="False"
                Opacity="0"
                InputTransparent="True"
                BackgroundColor="#80000000">

                <ActivityIndicator
                    x:Name="NavigationFeedbackSpinner"
                    IsRunning="False"
                    IsVisible="False"
                    WidthRequest="32"
                    HeightRequest="32"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Grid>

        </Grid>

    </Grid>
</ContentPage>
