<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JoesScanner.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:JoesScanner.ViewModels"
    xmlns:controls="clr-namespace:JoesScanner.Views.Controls"
    xmlns:models="clr-namespace:JoesScanner.Models"
    x:Name="Page"
    x:DataType="vm:MainViewModel"
    Title="Joes Scanner"
    BackgroundColor="{StaticResource TabStripNavy}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <!-- Root grid fills the window -->
    <Grid
        Padding="5,0,5,5"
        RowDefinitions="0,*"
        RowSpacing="0">

        <!-- Outer card that fills the available area -->
        <Border
            Grid.Row="1"
            StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#020617}"
            VerticalOptions="Fill"
            HorizontalOptions="Fill">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="10" />
            </Border.StrokeShape>

            <!-- Inner grid: header, calls, footer -->
            <Grid
                RowDefinitions="Auto,*,Auto"
                ColumnDefinitions="*"
                ColumnSpacing="0"
                Padding="2">

                <!-- HEADER PANEL: single merged box (buttons + indicators) -->
                <Border
                    Grid.Row="0"

                    BackgroundColor="#0D0D28"
                    Padding="2,0"
                    VerticalOptions="Center"
                    HorizontalOptions="Fill">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>

					<Grid
						ColumnDefinitions="Auto,Auto"
						ColumnSpacing="0"
						Padding="03"
						VerticalOptions="Center"
						HorizontalOptions="Center">

                        <!-- Media buttons strip -->
                        <ScrollView
                            x:Name="MediaButtonsScroll"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalOptions="Start"
                            HorizontalScrollBarVisibility="Never"
                            VerticalScrollBarVisibility="Never"
                            Padding="0,0,3,0"
                            Margin="0">

                            <HorizontalStackLayout
                                x:Name="MediaButtonsStack"
                                Spacing="0"
                                HorizontalOptions="Start"
                                VerticalOptions="Center">

                                <ImageButton
                                    Source="mc_previous.png"
                                    Command="{Binding PreviousCallCommand}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="60"
                                    WidthRequest="60"
                                    Padding="0"
                                    AutomationId="MediaPrevious"
                                    SemanticProperties.Description="Previous call"
                                    ToolTipProperties.Text="Previous call" />

                                <ImageButton
                                    Source="{Binding MediaPlayStopIcon}"
                                    Command="{Binding ToggleConnectionCommand}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="60"
                                    WidthRequest="60"
                                    Padding="0"
                                    AutomationId="MediaPlayStop"
                                    SemanticProperties.Description="Connect or disconnect"
                                    ToolTipProperties.Text="Connect or disconnect" />

                                <ImageButton
                                    Source="mc_next.png"
                                    Command="{Binding NextCallCommand}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="60"
                                    WidthRequest="60"
                                    Padding="0"
                                    AutomationId="MediaNext"
                                    SemanticProperties.Description="Next call"
                                    ToolTipProperties.Text="Next call" />

                                <ImageButton
                                    Source="mc_jump_to_live.png"
                                    Command="{Binding JumpToLiveCommand}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="60"
                                    WidthRequest="60"
                                    Padding="0"
                                    AutomationId="MediaJumpToLive"
                                    SemanticProperties.Description="Jump to live"
                                    ToolTipProperties.Text="Jump to live" />

                                <ImageButton
                                    Source="mc_volume.png"
                                    Clicked="OnAudioMenuClicked"
                                    BackgroundColor="Transparent"
                                    HeightRequest="60"
                                    WidthRequest="60"
                                    Padding="0"
                                    AutomationId="MediaVolume"
                                    SemanticProperties.Description="Audio options"
                                    ToolTipProperties.Text="Audio options" />

                            </HorizontalStackLayout>
                        </ScrollView>

                        <!-- Indicators area (fixed width) -->
						<Grid
                            x:Name="MediaIndicatorsPanel"
                            Grid.Column="1"
                            Padding="0"
                            RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                            ColumnDefinitions="*"
							InputTransparent="True"
                            VerticalOptions="Start">

                            <Border
                                WidthRequest="50"
                                HeightRequest="8"
                                Margin="0,3,0,0"
                                BackgroundColor="{Binding ConnectionStatusColor}"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4" />
                                </Border.StrokeShape>
                            </Border>

                            <Label
                                Grid.Row="1"
                                IsVisible="{Binding IsCallsWaitingVisible}"
                                Text="{Binding PlaybackSpeedLabel, StringFormat='Speed: {0}'}"
                                FontSize="10"
                                FontAutoScalingEnabled="False"
                                Margin="0,8,0,6"
                                LineBreakMode="NoWrap"
                                HorizontalTextAlignment="Center"
                                TextColor="White" />

                            <Label
                                Grid.Row="2"
                                IsVisible="{Binding IsCallsWaitingVisible}"
                                Text="{Binding CallsWaiting, StringFormat='Waiting: {0}'}"
                                FontSize="11"
                                FontAutoScalingEnabled="False"
                                LineBreakMode="NoWrap"
                                HorizontalTextAlignment="Center"
                                TextColor="White" />
                        </Grid>

                    </Grid>
                </Border>

                <!-- CALL LIST -->
                <CollectionView
                    Grid.Row="1"
                    x:Name="CallsView"
                    ItemsSource="{Binding Calls}"
                    SelectionMode="None"
                    ItemsUpdatingScrollMode="KeepScrollOffset"
                    ItemSizingStrategy="MeasureFirstItem"
                    HorizontalScrollBarVisibility="Never"
                    VerticalScrollBarVisibility="Never"
                    VerticalOptions="Fill"
                    HorizontalOptions="Center"
                    Margin="0,0,0,0">


                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CallItem">
                            <!-- Single call card -->
                            <Border
                                HorizontalOptions="Fill"
                                Padding="{OnPlatform WinUI=6, MacCatalyst=6, Android=5, iOS=5}"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCallTapped" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Border.Stroke>
                                    <SolidColorBrush Color="{AppThemeBinding Light=#374151, Dark=#1f2937}" />
                                </Border.Stroke>


                                <Border.Triggers>
                                    <DataTrigger
                                        TargetType="Border"
                                        Binding="{Binding IsToneHot}"
                                        Value="True">
                                        <Setter Property="StrokeThickness" Value="2" />
                                        <Setter Property="Stroke" Value="#ef4444" />
                                    </DataTrigger>

                                    <DataTrigger
                                        TargetType="Border"
                                        Binding="{Binding IsPlaying}"
                                        Value="True">
                                        <Setter Property="StrokeThickness" Value="2" />
                                        <Setter Property="Stroke" Value="#22c55e" />
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light=#ecfdf5, Dark=#022c22}" />
                                        <Setter Property="Opacity" Value="1" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <!-- Call layout: header row, transcription, debug -->
                                <Grid
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto,Auto,Auto,Auto"
                                    RowSpacing="{OnPlatform WinUI=4, MacCatalyst=4, Android=2, iOS=2}"
                                    ColumnSpacing="6">

                                    <!-- Header row: time > receiver > site > talkgroup -->
                                    <Label
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        FontSize="{OnPlatform WinUI=12, MacCatalyst=12, Android=11, iOS=11}"
                                        FontAutoScalingEnabled="False"
                                        MaxLines="1"
                                        LineBreakMode="TailTruncation">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span
                                                    Text="{Binding TimeOnlyDisplay}"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light=#111827, Dark=White}" />
                                                <Span Text=" > " />
                                                <Span
                                                    Text="{Binding ReceiverName}"
                                                    TextColor="{AppThemeBinding Light=#374151, Dark=#9ca3af}" />
                                                <Span Text=" > " />
                                                <Span
                                                    Text="{Binding SystemName}"
                                                    TextColor="{AppThemeBinding Light=#374151, Dark=#9ca3af}" />
                                                <Span Text=" > " />
                                                <Span
                                                    Text="{Binding Talkgroup}"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light=#111827, Dark=#bfdbfe}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- Duration on the right (show muted marker when applicable) -->
                                    <HorizontalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Spacing="4"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center">

                                        <Label
                                            Text="M"
                                            FontSize="{OnPlatform WinUI=9, MacCatalyst=9, Android=8, iOS=8}"
                                            FontAutoScalingEnabled="False"
                                            TextColor="#dc2626"
                                            IsVisible="{Binding IsMutedByFilter}" />

                                        <Label
                                            HorizontalTextAlignment="End"
                                            VerticalTextAlignment="Center"
                                            FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                            FontAutoScalingEnabled="False"
                                            Text="{Binding DurationDisplay}"
                                            TextColor="{AppThemeBinding Light=#4b5563, Dark=#9ca3af}" />
                                    </HorizontalStackLayout>

                                    <!-- Transcription (only show when there is real text) -->
                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,2,0,0"
                                        FontSize="{OnPlatform WinUI=12, MacCatalyst=12, Android=11, iOS=11}"
                                        FontAutoScalingEnabled="False"
                                        LineBreakMode="WordWrap"
                                        TextColor="{AppThemeBinding Light=#374151, Dark=#e5e7eb}"
                                        MaxLines="4"
                                        Text="{Binding Transcription, TargetNullValue=''}">

                                        <Label.Triggers>
                                            <!-- Hide when empty -->
                                            <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding Transcription, TargetNullValue=''}"
                                                Value="">
                                                <Setter Property="IsVisible" Value="False" />
                                                <Setter Property="Margin" Value="0" />
                                            </DataTrigger>

                                            <!-- Hide when server sends the placeholder string -->
                                            <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding Transcription, TargetNullValue=''}"
                                                Value="No transcription from server">
                                                <Setter Property="IsVisible" Value="False" />
                                                <Setter Property="Margin" Value="0" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    
                                    <!-- Address detection -->
                                    <Grid
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,2,0,0"
                                        ColumnDefinitions="Auto,Auto"
                                        RowDefinitions="Auto"
                                        IsVisible="{Binding HasDetectedAddress}">

                                        <Label
                                            Grid.Column="0"
                                            FontSize="{OnPlatform WinUI=11, MacCatalyst=11, Android=10, iOS=10}"
                                            FontAutoScalingEnabled="False"
                                            MaxLines="2"
                                            LineBreakMode="TailTruncation"
                                            TextColor="{AppThemeBinding Light=#2563eb, Dark=#60a5fa}"
                                            TextDecorations="Underline"
                                            Text="{Binding DetectedAddress}">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="OnDetectedAddressTapped"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <Label
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalTextAlignment="Center"
                                            FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                            FontAutoScalingEnabled="False"
                                            TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                                            LineBreakMode="NoWrap"
                                            MaxLines="1"
                                            Text="{Binding DetectedAddressConfidencePercent, StringFormat='{0}%'}" />
                                    </Grid>

<!-- what3words -->
                                    <VerticalStackLayout
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,2,0,0"
                                        Spacing="1"
                                        IsVisible="{Binding HasWhat3WordsAddress}">

                                        <VerticalStackLayout.Triggers>
                                            <DataTrigger
                                                TargetType="VerticalStackLayout"
                                                Binding="{Binding Source={x:Reference Page}, Path=BindingContext.What3WordsLinksEnabled}"
                                                Value="False">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </VerticalStackLayout.Triggers>

                                        <Label
                                            FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                            FontAutoScalingEnabled="False"
                                            TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                                            LineBreakMode="NoWrap"
                                            MaxLines="1"
                                            Text="what3words" />

                                        
                                        <HorizontalStackLayout Spacing="10">
                                            <Label
                                                FontSize="{OnPlatform WinUI=11, MacCatalyst=11, Android=10, iOS=10}"
                                                FontAutoScalingEnabled="False"
                                                MaxLines="1"
                                                LineBreakMode="TailTruncation"
                                                TextColor="{AppThemeBinding Light=#2563eb, Dark=#60a5fa}"
                                                TextDecorations="Underline"
                                                Text="{Binding What3WordsAddress}">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Tapped="OnWhat3WordsTapped"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <Label
                                                FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                                FontAutoScalingEnabled="False"
                                                TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                                                TextDecorations="Underline"
                                                VerticalOptions="Center"
                                                Text="Copy">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Tapped="OnWhat3WordsCopyTapped"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </HorizontalStackLayout>


                                        
                                        <HorizontalStackLayout
                                            IsVisible="{Binding HasWhat3WordsCoordinates}"
                                            Spacing="10">

                                            <Label
                                                FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                                FontAutoScalingEnabled="False"
                                                TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                                                LineBreakMode="NoWrap"
                                                MaxLines="1"
                                                Text="{Binding What3WordsCoordinatesText}" />

                                            <Label
                                                FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                                FontAutoScalingEnabled="False"
                                                TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                                                TextDecorations="Underline"
                                                VerticalOptions="Center"
                                                Text="Copy coords">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Tapped="OnWhat3WordsCoordsCopyTapped"
                                                        CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                        </HorizontalStackLayout>


                                    </VerticalStackLayout>
<!-- Debug or error info -->
                                    <Label
                                        Grid.Row="4"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Margin="0,2,0,0"
                                        FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                        FontAutoScalingEnabled="False"
                                        LineBreakMode="WordWrap"
                                        MaxLines="3"
                                        TextColor="{AppThemeBinding Light=#b91c1c, Dark=#fecaca}"
                                        IsVisible="{Binding HasDebugInfo}"
                                        Text="{Binding DebugInfo}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- FOOTER: client info and donate button -->
                <Grid
                    Grid.Row="2"
                    Padding="20,5,20,5"
                    RowDefinitions="Auto"
                    ColumnDefinitions="*,Auto">

                    <!-- Desktop only label -->
                    <Label
                        Grid.Row="0"
                        Grid.Column="0"
                        FontSize="11"
                        VerticalOptions="End"
                        TextColor="{AppThemeBinding Light=#6b7280, Dark=#9ca3af}"
                        LineBreakMode="TailTruncation"
                        IsVisible="{OnPlatform WinUI=true, MacCatalyst=true, Android=false, iOS=false}"
                        Text="JoesScanner desktop client">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSiteTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Donate button -->
                    <Button
                        Grid.Column="1"
                        Text="{OnPlatform iOS='About the developer', Default='Donate to the app developer'}"
                        Style="{StaticResource SecondaryPillButtonStyle}"
                        FontSize="10"
                        HorizontalOptions="End"
                        Command="{Binding OpenDonateCommand}" />
                </Grid>

            </Grid>
        </Border>
    
<!-- Address alert stack (max 3). Tap to jump to call, swipe or X to dismiss. -->
<VerticalStackLayout
    Grid.Row="1"
    Margin="8"
    VerticalOptions="End"
    HorizontalOptions="Fill"
    Spacing="6"
    ZIndex="99"
    IsVisible="{Binding HasAddressAlerts}">

        <VerticalStackLayout
        BindableLayout.ItemsSource="{Binding AddressAlerts}"
        Spacing="6">

        <BindableLayout.ItemTemplate>
            <DataTemplate x:DataType="models:CallItem">
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems Mode="Execute">
                            <SwipeItem
                                Text="Dismiss"
                                BackgroundColor="{AppThemeBinding Light=#ef4444, Dark=#b91c1c}"
                                Invoked="OnAlertDismissInvoked"
                                CommandParameter="{Binding .}" />
                        </SwipeItems>
                    </SwipeView.RightItems>

                    <Border
                        Padding="10"
                        BackgroundColor="{AppThemeBinding Light=#f8fafc, Dark=#0b1220}"
                        Stroke="{AppThemeBinding Light=#cbd5e1, Dark=#334155}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAlertTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid RowDefinitions="Auto,Auto">
                            <Label
                                Grid.Row="0"
                                FontSize="{OnPlatform WinUI=12, MacCatalyst=12, Android=11, iOS=11}"
                                FontAutoScalingEnabled="False"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                TextColor="{AppThemeBinding Light=#0f172a, Dark=#e5e7eb}"
                                Margin="0,0,22,0"
                                Text="{Binding DetectedAddress}" />

                            <Label
                                Grid.Row="1"
                                FontSize="{OnPlatform WinUI=10, MacCatalyst=10, Android=9, iOS=9}"
                                FontAutoScalingEnabled="False"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                TextColor="{AppThemeBinding Light=#475569, Dark=#9ca3af}"
                                Margin="0,0,22,0"
                                Text="{Binding Talkgroup}" />

                            <Label
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                FontSize="16"
                                FontAutoScalingEnabled="False"
                                TextColor="{AppThemeBinding Light=#64748b, Dark=#9ca3af}"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,-2,-2,0"
                                Text="✕">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAlertDismissTapped" CommandParameter="{Binding .}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </SwipeView>
            </DataTemplate>
        </BindableLayout.ItemTemplate>
    </VerticalStackLayout>
</VerticalStackLayout>


    <!-- Audio speed menu overlay (reliable on Windows, no Navigation or ActionSheet) -->
    <Grid
        x:Name="AudioMenuOverlay"
        Grid.RowSpan="2"
        IsVisible="False"
        BackgroundColor="#66000000"
        ZIndex="999">

        <!-- Backdrop -->
        <BoxView
            BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAudioMenuBackdropTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Menu panel -->
        <Border
            ZIndex="1000"
            BackgroundColor="#0D0D28"
            StrokeThickness="0"
            Padding="10"
            HorizontalOptions="Center"
            VerticalOptions="Start"
            Margin="0,60,0,0">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Button Text="Off" Clicked="OnAudioMenuOptionClicked" CommandParameter="Off" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
                <Button Text="1x" Clicked="OnAudioMenuOptionClicked" CommandParameter="0" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
                <Button Text="1.25x" Clicked="OnAudioMenuOptionClicked" CommandParameter="1" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
                <Button Text="1.5x" Clicked="OnAudioMenuOptionClicked" CommandParameter="2" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
                <Button Text="1.75x" Clicked="OnAudioMenuOptionClicked" CommandParameter="3" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
                <Button Text="2x" Clicked="OnAudioMenuOptionClicked" CommandParameter="4" WidthRequest="88" HeightRequest="34" Padding="8,2" FontAttributes="Bold" FontSize="13" BackgroundColor="#2563eb" TextColor="White" BorderColor="#93c5fd" BorderWidth="1" CornerRadius="10" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

    </Grid>

</Grid>
</ContentPage>